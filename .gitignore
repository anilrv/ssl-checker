# --- Go backend (Azure Functions) ---
backend/bin/
backend/obj/
backend/*.log

# Azure Functions local dev settings — holds connection strings/keys for local runs,
# never meant to leave the machine (this is Microsoft's own standard exclusion).
backend/local.settings.json

# --- Release artifacts ---
# The whole directory stays out of git: the Web Store manifest signing key (a secret
# that must never enter history), built upload zips, and store-listing screenshots.
release/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp

# --- Playwright MCP session artifacts ---
.playwright-mcp/

# --- Env files (defensive — none exist yet, but never commit if added later) ---
.env
.env.local
